# ── LegionForge TestLab ───────────────────────────────────────────────────────
# Docker image for the admin test management UI (:8090).
#
# What it runs:
#   uvicorn src.testlab.app:app --host 0.0.0.0 --port 8090
#
# Requirements:
#   TESTLAB_ADMIN_KEY  — admin API key (env var; skips Keychain)
#
# Optional (for integration / LLM test generation):
#   POSTGRES_PASSWORD  — PostgreSQL password
#   TASK_TOKEN_SECRET  — JWT signing secret
#   OLLAMA_BASE_URL    — Ollama endpoint (default: http://host.docker.internal:11434)
#
# Build:
#   docker build -f Dockerfile.testlab -t legionforge-testlab:latest .
#
# Run (read-only volume for test files, writable for edits):
#   docker run --rm -p 8090:8090 \
#     -e TESTLAB_ADMIN_KEY=<key> \
#     -v $(pwd)/tests:/app/tests \       # mount live tests (editable)
#     -v $(pwd)/src:/app/src:ro \        # mount src (read-only for LLM context)
#     --add-host host.docker.internal:host-gateway \
#     legionforge-testlab:latest
# ─────────────────────────────────────────────────────────────────────────────

FROM python:3.11-slim AS base

# System dependencies for Playwright Chromium + build tools
RUN apt-get update && apt-get install -y --no-install-recommends \
      make \
      git \
      curl \
      # Playwright Chromium dependencies
      libnss3 libnspr4 libdbus-1-3 libatk1.0-0 libatk-bridge2.0-0 \
      libcups2 libdrm2 libxkbcommon0 libxcomposite1 libxdamage1 \
      libxfixes3 libxrandr2 libgbm1 libasound2 libpango-1.0-0 \
      libcairo2 libatspi2.0-0 libx11-6 libxext6 \
    && rm -rf /var/lib/apt/lists/*

# ── App ───────────────────────────────────────────────────────────────────────
WORKDIR /app

# Install Python dependencies (layer-cached unless requirements.txt changes)
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright Chromium browser
RUN python -m playwright install chromium

# Copy source (src/ and tests/ will be overridden by volume mounts at runtime)
COPY src/ ./src/
COPY tests/ ./tests/
COPY config/ ./config/
COPY pytest.ini .
COPY Makefile .

# ── Security: non-root user ───────────────────────────────────────────────────
RUN useradd --create-home --shell /bin/bash testlab
# Allow testlab user to write to tests/ (for file editor)
RUN chown -R testlab:testlab /app/tests
USER testlab

# ── Runtime ───────────────────────────────────────────────────────────────────
ENV PYTHONPATH=/app \
    PYTHONUNBUFFERED=1 \
    AGENT_HARDWARE_PROFILE=mac_m4_mini_16gb \
    # Override Ollama to talk to host
    OLLAMA_BASE_URL=http://host.docker.internal:11434

EXPOSE 8090

HEALTHCHECK --interval=30s --timeout=5s --start-period=30s --retries=3 \
    CMD curl -f http://localhost:8090/health || exit 1

CMD ["uvicorn", "src.testlab.app:app", "--host", "0.0.0.0", "--port", "8090", \
     "--log-level", "info"]
